import java.util.Scanner;
import java.util.Locale;

public class tab {
    public static void main(String[] args) {

        Scanner k = new Scanner(System.in);
        k.useLocale(Locale.US);
        double num, tab, res;
        int cont;
        cont = 1;

        System.out.println("insira o numero da tabuda: ");
        num = k.nextDouble();

        System.out.println("insira a quantidade de vezes que o número for multiplicado: ");
        tab = k.nextDouble();

        while (cont <= tab) {

            res = num * cont;
            System.out.println(num +" X " + cont + " = " + res);

            ++cont;

        }



    }
}
