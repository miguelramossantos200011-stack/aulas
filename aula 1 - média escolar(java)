
import java.util.Locale;
import java.util.Scanner;

import static java.lang.Math.*;

public class Main {
    static void main(String[] args) {

        Scanner entrada = new Scanner(System.in);
        entrada.useLocale(Locale.US);



        double n;
        double r;
        double nn;
        int cont;
        cont = 1;
        int trabe;
        r = 0;
        trabe = 0;
        int trabecont;
        trabecont = 0;
        String mat;
        double  aula;
        aula = 0;
        double pres;
        pres = 0;
        double freq;
        freq = 0;
        String email;
        String senha1 = ("");


        System.out.print("insira seu e-mail: ");
        email = entrada.nextLine();

        System.out.print("insira sua senha: ");
        String senha = entrada.nextLine();

        System.out.print("faça seu login ");

        while (!senha.equals(senha1)) {

            System.out.println("olá, " + email);

            System.out.println("insira sua senha: ");
            senha1 = entrada.nextLine();
        }

        System.out.print("insira a matéria: ");
        mat = entrada.nextLine();

        System.out.print("insira a qantidade de aulas dadas: ");
        aula = entrada.nextInt();

        System.out.print("insira a qantidade de presenças: ");
        pres = entrada.nextInt();

        while (4 >= cont) {
                System.out.print("insira a nota do " + cont + "º bimestre: ");
