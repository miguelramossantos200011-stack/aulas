            r = n + r;
            ++cont;
            trabecont = trabe + trabecont;
        }
        nn = r / 4;
        freq = (pres / aula);


        if (nn >= 7 && trabe >= 4 && freq >= 0.5) {
            System.out.println("o/a "+ email + " está aprovado em " + mat + ", média = " + nn +", trabalhos entregues "+ trabecont +". Frequência = " + freq + "%");
        }
        else{
            System.out.println("o/a "+ email + " está Reprovado em " + mat + ", média = " + nn +", trabalhos entregues "+ trabecont +". Frequência = " + freq + "%");

        }

        if (nn <= 7) {
            System.out.println(" Reprovado por nota baixa");
        }
        if (trabe <= 4) {
            System.out.println(" Reprovado por falta de trabalhos entregues");
        }
        if (freq <= 0.5) {
            System.out.println(" Reprovado por faltas");
        }

    }


}


